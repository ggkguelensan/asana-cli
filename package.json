{
  "name": "asana-cli",
  "version": "0.4.0",
  "description": "A single-binary developer CLI for the Asana API",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "asana-cli": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --no-env-file src/index.ts",
    "test": "bun test",
    "lint:types": "bun run scripts/check-types.ts",
    "typecheck": "bunx tsc --noEmit && bun run lint:types",
    "build": "bun run --no-env-file scripts/build.ts",
    "build:darwin-arm64": "bun run --no-env-file scripts/build.ts bun-darwin-arm64 dist/asana-cli-darwin-arm64",
    "build:darwin-x64": "bun run --no-env-file scripts/build.ts bun-darwin-x64 dist/asana-cli-darwin-x64",
    "build:linux-x64": "bun run --no-env-file scripts/build.ts bun-linux-x64-baseline dist/asana-cli-linux-x64",
    "build:linux-arm64": "bun run --no-env-file scripts/build.ts bun-linux-arm64 dist/asana-cli-linux-arm64",
    "build:linux-x64-musl": "bun run --no-env-file scripts/build.ts bun-linux-x64-baseline-musl dist/asana-cli-linux-x64-musl",
    "build:linux-arm64-musl": "bun run --no-env-file scripts/build.ts bun-linux-arm64-musl dist/asana-cli-linux-arm64-musl",
    "generate:integrations": "bun run --no-env-file scripts/generate-integrations.ts",
    "generate:client-compatibility": "bun run --no-env-file scripts/generate-client-compatibility.ts",
    "generate:gemini-extension": "bun run --no-env-file scripts/generate-gemini-extension.ts",
    "generate:release-sbom": "bun run --no-env-file scripts/release-sbom.ts",
    "generate:homebrew-formula": "bun run --no-env-file scripts/homebrew-formula.ts",
    "generate:release-checksums": "bun run --no-env-file scripts/release-assets.ts",
    "generate:reproducible-build": "bun run --no-env-file scripts/reproducible-build.ts",
    "check:generated-integrations": "bun run --no-env-file scripts/check-generated-integrations.ts",
    "check:client-compatibility": "bun run --no-env-file scripts/check-client-compatibility.ts",
    "check:gemini-extension": "bun run --no-env-file scripts/check-gemini-extension.ts",
    "check:package-content": "bun run --no-env-file scripts/check-package-content.ts",
    "check:project-plan": "bun run --no-env-file scripts/check-project-plan.ts",
    "check:support-matrix": "bun run --no-env-file scripts/check-support-matrix.ts",
    "check:client-evidence": "bun run --no-env-file scripts/check-client-evidence.ts",
    "check:native-client-evidence": "bun run --no-env-file scripts/check-native-client-evidence.ts",
    "check:integration-lifecycle-evidence": "bun run --no-env-file scripts/check-integration-lifecycle-evidence.ts",
    "check:release-sbom": "bun run --no-env-file scripts/check-release-sbom.ts",
    "check:release-assets": "bun run --no-env-file scripts/check-release-assets.ts",
    "check:release-workflow": "bun run --no-env-file scripts/check-release-workflow.ts",
    "eval:codex": "bun run --no-env-file scripts/run-client-evals.ts --client codex --executable codex --binary dist/asana-cli --output evidence/client-evals/codex.json",
    "eval:claude-code": "bun run --no-env-file scripts/run-client-evals.ts --client claude-code --executable claude --binary dist/asana-cli --output evidence/client-evals/claude-code.json",
    "eval:opencode-discovery": "bun run --no-env-file scripts/native-client-discovery.ts --executable opencode --binary dist/asana-cli --output evidence/client-adapters/opencode.json",
    "eval:gemini-discovery": "bun run --no-env-file scripts/gemini-native-discovery.ts --executable npm --binary dist/asana-cli --output evidence/client-adapters/gemini-cli.json",
    "eval:copilot-discovery": "bun run --no-env-file scripts/copilot-native-discovery.ts --executable npm --binary dist/asana-cli --output evidence/client-adapters/github-copilot.json",
    "test:integration-lifecycle": "bun run --no-env-file scripts/integration-lifecycle-e2e.ts dist/asana-cli",
    "release:contract": "bun run --no-env-file scripts/release-contract.ts",
    "release:preflight": "bun run --no-env-file scripts/release-preflight.ts",
    "check": "bun run typecheck && bun run check:generated-integrations && bun run check:client-compatibility && bun run check:gemini-extension && bun run check:project-plan && bun run check:support-matrix && bun run check:release-workflow && bun run check:client-evidence && bun run check:native-client-evidence && bun run check:integration-lifecycle-evidence && bun run build && bun run check:package-content && bun test && ./dist/asana-cli --version"
  },
  "dependencies": {
    "asana": "3.1.12",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT"
}
