{
  "name": "asana-cli",
  "version": "0.3.0",
  "description": "A single-binary developer CLI for the Asana API",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "asana-cli": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --no-env-file src/index.ts",
    "test": "bun test",
    "lint:types": "bun run scripts/check-types.ts",
    "typecheck": "bunx tsc --noEmit && bun run lint:types",
    "build": "bun run --no-env-file scripts/build.ts",
    "build:darwin-arm64": "bun run --no-env-file scripts/build.ts bun-darwin-arm64 dist/asana-cli-darwin-arm64",
    "build:darwin-x64": "bun run --no-env-file scripts/build.ts bun-darwin-x64 dist/asana-cli-darwin-x64",
    "build:linux-x64": "bun run --no-env-file scripts/build.ts bun-linux-x64-baseline dist/asana-cli-linux-x64",
    "build:linux-arm64": "bun run --no-env-file scripts/build.ts bun-linux-arm64 dist/asana-cli-linux-arm64",
    "build:windows-x64": "bun run --no-env-file scripts/build.ts bun-windows-x64-baseline dist/asana-cli-windows-x64.exe",
    "release:preflight": "bun run --no-env-file scripts/release-preflight.ts",
    "check": "bun run typecheck && bun run build && bun test && ./dist/asana-cli --version"
  },
  "dependencies": {
    "asana": "3.1.12",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT"
}
